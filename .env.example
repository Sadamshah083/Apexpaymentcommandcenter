APP_NAME="ApexOne Command Center"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_ALLOW_INSECURE_HTTP_IN_LOCAL=false

# Outbound HTTPS (Windows/local PHP: use bundled CA at storage/certs/cacert.pem)
# HTTP_SSL_VERIFY=false
# CURL_CA_BUNDLE=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

# PAGINATION_LEADS_PER_PAGE=20
# PAGINATION_PIPELINE_LEADS_PER_PAGE=25
# PAGINATION_WORKFLOWS_PER_PAGE=8

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Use 1 worker with SQLite to avoid "database is locked" during parallel lead enrichment
QUEUE_WORKERS=1
# DB_QUEUE_RETRY_AFTER=200

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-20b:free
OPENROUTER_FALLBACK_MODELS=openrouter/free,meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_WEB_SEARCH_ENABLED=true
OPENROUTER_DUCKDUCKGO_FALLBACK=true

BUSINESS_RESEARCH_PROVIDER=gemini
BUSINESS_RESEARCH_WEB_CONTEXT_FIRST=true
BUSINESS_RESEARCH_MAX_SEARCH_QUERIES=14
BUSINESS_RESEARCH_FOLLOW_UP=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash
GEMINI_GOOGLE_SEARCH_ENABLED=true
GEMINI_THINKING_BUDGET=4096
GEMINI_TIMEOUT=240
GEMINI_PROJECT_NUMBER=

CRM_REUSE_RESEARCH=true
CRM_WEB_CONTEXT_FIRST=false
CRM_MAX_DDG_QUERIES=3
CRM_RE_RESEARCH_ON_CHANGE=true
CRM_DISPATCH_DELAY_MS=0
CRM_GEMINI_MODEL=gemini-2.5-flash
CRM_GEMINI_FALLBACK_MODELS=gemini-2.0-flash
CRM_GEMINI_THINKING_BUDGET=0
CRM_GEMINI_TIMEOUT=90
CRM_MAX_OUTPUT_TOKENS=8192
CRM_FOLLOW_UP=false
CRM_REFRESH_COUNTS_INTERVAL=5

WEBPUSH_PUBLIC_KEY=
WEBPUSH_PRIVATE_KEY=
WEBPUSH_SUBJECT="${MAIL_FROM_ADDRESS}"

# Zoom (Communications Hub)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET=
